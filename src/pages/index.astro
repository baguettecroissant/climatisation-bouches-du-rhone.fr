---
import Layout from '../layouts/Layout.astro';
import StepsForm from '../components/StepsForm.astro';
import config from '../data/config.json';
import communes from '../data/communes.json';

const title = "Climatisation & Pompe à Chaleur Bouches-du-Rhône (13) | Artisans RGE";
const description = "Climatisation réversible & PAC air-air réversible dans les Bouches-du-Rhône (13). Obtenez 3 devis gratuits d'installateurs qualifiés RGE. Pose rapide sous 48h.";

// We can show top 6 communes on home page
const featuredCommunes = communes.slice(0, 6);
---

<Layout title={title} description={description} activeTab="home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container two-column-layout">
      <div>
        <span class="badge-pill" style="background:#f97316; border-color:#ffedd5; margin-bottom:15px;">
          🔥 Urgence Canicule — Pose sous 48h
        </span>
        <h1 style="font-size:42px; line-height:1.2; margin-bottom:20px; font-weight:700;">
          Climatisation réversible dans les Bouches-du-Rhône (13)
        </h1>
        <p style="font-size:18px; margin-bottom:25px; opacity:0.95; line-height:1.6;">
          Ne subissez plus les fortes chaleurs provencales. Équipez votre maison ou appartement d'une climatisation réversible performante et économe. Divisez par 3 votre facture de chauffage en hiver.
        </p>

        <div style="background:rgba(255,255,255,0.08); border:1.5px solid rgba(255,255,255,0.15); border-radius:15px; padding:20px; font-size:15px; line-height:1.6;">
          <strong>📊 Chiffres clés du marché 2026 :</strong>
          <ul style="list-style:none; margin-top:10px; display:flex; flex-direction:column; gap:8px;">
            <li>❄️ Canicules : <span class="temp-fall-animate">🌡️</span> Jusqu'à <strong>45°C+</strong> constatés dans l'arrière-pays.</li>
            <li>❄️ Artisans Qualipac : <strong>120+ frigoristes qualifiés RGE</strong> actifs dans le 13.</li>
            <li>❄️ Primes Énergie : <strong>CEE & TVA 10% éligibles</strong> sur la pose d'une PAC Air-Air.</li>
          </ul>
        </div>
      </div>

      <div>
        <StepsForm />
      </div>
    </div>
  </section>

  <!-- Interactive Power Simulator -->
  <section style="padding:60px 0; background:white;">
    <div class="container" style="max-width:800px; text-align:center;">
      <h2 style="color:var(--primary); margin-bottom:15px;">Simulateur de puissance Climatisation</h2>
      <p style="color:var(--text-muted); margin-bottom:35px; font-size:16px;">
        Calculez la puissance en kW nécessaire pour climatiser votre pièce principale dans les Bouches-du-Rhône.
      </p>

      <div style="background:var(--primary-light); border:2px solid var(--border-color); padding:30px; border-radius:var(--radius-md); text-align:left; box-shadow:var(--shadow-sm);">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
          <div class="form-group">
            <label for="sim-surface">Surface à équiper (m²)</label>
            <input type="number" id="sim-surface" class="form-control" value="35" min="10" max="200" />
          </div>
          <div class="form-group">
            <label for="sim-isolation">Qualité de l'isolation</label>
            <select id="sim-isolation" class="form-control" style="padding:0 15px;">
              <option value="0.8">Excellente (RT2020 / BBC)</option>
              <option value="1.0" selected>Standard (RT2012)</option>
              <option value="1.3">Moyenne / Ancienne</option>
              <option value="1.6">Mauvaise / Non isolée</option>
            </select>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:15px;">
          <div class="form-group">
            <label for="sim-orientation">Orientation de la pièce</label>
            <select id="sim-orientation" class="form-control" style="padding:0 15px;">
              <option value="1.0">Nord (Peu ensoleillé)</option>
              <option value="1.1" selected>Est / Ouest (Ensoleillement moyen)</option>
              <option value="1.25">Sud / Sud-Ouest (Ensoleillement fort)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="sim-etage">Situation de l'étage</label>
            <select id="sim-etage" class="form-control" style="padding:0 15px;">
              <option value="1.0" selected>Rez-de-chaussée / Intermédiaire</option>
              <option value="1.2">Sous les combles / Dernier étage</option>
            </select>
          </div>
        </div>

        <div style="text-align:center; margin-top:30px; border-top:1px solid var(--border-color); padding-top:25px;">
          <span style="font-size:16px; color:var(--text-muted); display:block; margin-bottom:8px;">Puissance estimée requise :</span>
          <span id="sim-result" style="font-family:var(--font-mono); font-size:36px; font-weight:800; color:var(--secondary);">3.8 kW</span>
          <p style="font-size:13px; color:var(--text-muted); margin-top:8px;">
            *Estimation indicative. Un bilan thermique complet par un installateur RGE est nécessaire avant l'achat.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Split vs Gainable Comparison -->
  <section style="padding:80px 0; background:var(--primary-light);">
    <div class="container">
      <div style="text-align:center; margin-bottom:50px;">
        <h2 style="color:var(--primary); margin-bottom:15px;">Comparateur de systèmes : Split vs Gainable</h2>
        <p style="color:var(--text-muted); font-size:16px; max-width:700px; margin:0 auto;">
          Choisissez le type de climatiseur le plus adapté à l'architecture de votre logement dans les Bouches-du-Rhône.
        </p>
      </div>

      <div style="background:white; border:2px solid var(--border-color); border-radius:var(--radius-md); overflow:hidden; box-shadow:var(--shadow-sm);">
        <table style="width:100%; border-collapse:collapse; text-align:left; font-size:16px;">
          <thead>
            <tr style="background:var(--primary); color:white;">
              <th style="padding:20px; font-weight:700; color:white;">Caractéristique</th>
              <th style="padding:20px; font-weight:700; color:white;">Split Mural réversible</th>
              <th style="padding:20px; font-weight:700; color:white;">Climatisation Gainable</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:20px; font-weight:700; color:var(--primary);">Aspect visuel</td>
              <td style="padding:20px; color:var(--text-muted);">Unité blanche murale visible</td>
              <td style="padding:20px; color:var(--text-muted);">Totalement invisible (grilles au plafond)</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:20px; font-weight:700; color:var(--primary);">Installation</td>
              <td style="padding:20px; color:var(--text-muted);">Rapide (1 à 2 jours), peu de travaux</td>
              <td style="padding:20px; color:var(--text-muted);">Création de faux-plafond (3 à 5 jours)</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:20px; font-weight:700; color:var(--primary);">Régulation de température</td>
              <td style="padding:20px; color:var(--text-muted);">Pièce par pièce (télécommande)</td>
              <td style="padding:20px; color:var(--text-muted);">Thermostat centralisé ou multizone (Airzone)</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:20px; font-weight:700; color:var(--primary);">Niveau sonore</td>
              <td style="padding:20px; color:var(--text-muted);">Très silencieux (19-22 dB)</td>
              <td style="padding:20px; color:var(--text-muted);">Ultra-silencieux (moteur dans les combles)</td>
            </tr>
            <tr>
              <td style="padding:20px; font-weight:700; color:var(--primary);">Budget moyen TTC posé</td>
              <td style="padding:20px; font-weight:700; color:var(--secondary); font-family:var(--font-mono);">1 500 € – 2 500 €</td>
              <td style="padding:20px; font-weight:700; color:var(--secondary); font-family:var(--font-mono);">6 000 € – 12 000 €</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing section -->
  <section style="padding:80px 0; background:white;">
    <div class="container">
      <div style="text-align:center; margin-bottom:50px;">
        <h2 style="color:var(--primary); margin-bottom:15px;">Tarifs indicatifs climatisation Bouches-du-Rhône (2026)</h2>
        <p style="color:var(--text-muted); font-size:16px; max-width:750px; margin:0 auto;">
          Découvrez la grille tarifaire moyenne constatée pour l'achat et la pose d'un climatiseur réversible par un artisan qualifié RGE dans le 13.
        </p>
      </div>

      <div class="grid-3">
        <div class="card" style="text-align:center;">
          <h3 style="color:var(--primary); margin-bottom:10px;">Mono-Split Mural</h3>
          <span class="price-tag" style="font-size:32px; color:var(--secondary); margin-bottom:15px; display:block;">1 200€ – 2 500€</span>
          <p style="font-size:15px; color:var(--text-muted); line-height:1.5; margin-bottom:20px;">
            Idéal pour équiper une seule pièce (salon de 30m² ou chambre principale). Technologie Inverter A+++.
          </p>
          <a href="/devis/" class="btn-secondary" style="width:100%;">Demander un devis</a>
        </div>

        <div class="card" style="text-align:center; border-color:var(--secondary); transform: scale(1.03); box-shadow:var(--shadow-md);">
          <div style="background:var(--secondary); color:white; font-size:11px; font-weight:700; text-transform:uppercase; padding:4px 10px; border-radius:10px; display:inline-block; margin-bottom:15px;">Le plus demandé dans le 13</div>
          <h3 style="color:var(--primary); margin-bottom:10px;">Multi-Split (2-3 unités)</h3>
          <span class="price-tag" style="font-size:32px; color:var(--secondary); margin-bottom:15px; display:block;">2 800€ – 5 500€</span>
          <p style="font-size:15px; color:var(--text-muted); line-height:1.5; margin-bottom:20px;">
            1 unité extérieure connectée à 2 ou 3 splits intérieurs. Température indépendante par pièce.
          </p>
          <a href="/devis/" class="btn-primary" style="width:100%;">Demander un devis</a>
        </div>

        <div class="card" style="text-align:center;">
          <h3 style="color:var(--primary); margin-bottom:10px;">Climatisation Gainable</h3>
          <span class="price-tag" style="font-size:32px; color:var(--secondary); margin-bottom:15px; display:block;">5 000€ – 12 000€</span>
          <p style="font-size:15px; color:var(--text-muted); line-height:1.5; margin-bottom:20px;">
            Invisible, intégration en plénum. Idéal pour les bastides aixoises ou grandes maisons individuelles.
          </p>
          <a href="/devis/" class="btn-secondary" style="width:100%;">Demander un devis</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Localized towns list -->
  <section style="padding:60px 0; background:var(--primary-light);">
    <div class="container" style="text-align:center;">
      <h2 style="color:var(--primary); margin-bottom:15px;">Nos installateurs dans les Bouches-du-Rhône</h2>
      <p style="color:var(--text-muted); font-size:16px; margin-bottom:40px; max-width:700px; margin:0 auto 40px;">
        Nous couvrons l'intégralité du département 13 pour l'étude thermique gratuite et l'installation de votre PAC air-air.
      </p>

      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:15px; text-align:left;">
        {featuredCommunes.map(c => (
          <a href={`/climatisation-${c.slug}/`} style="background:white; border:1px solid var(--border-color); padding:15px; border-radius:10px; text-decoration:none; display:flex; justify-content:space-between; align-items:center; transition:var(--transition); box-shadow:var(--shadow-sm);">
            <div style="display:flex; flex-direction:column;">
              <strong style="color:var(--primary); font-size:15px;">{c.nom}</strong>
              <span style="font-size:12px; color:var(--text-muted);">{c.codePostal}</span>
            </div>
            <span style="color:var(--secondary); font-weight:700;">&rarr;</span>
          </a>
        ))}
      </div>

      <div style="margin-top:35px;">
        <a href="/communes/" style="font-weight:700; color:var(--primary); text-decoration:none;">
          Voir toutes les communes couvertes (100+) &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Interactive script for power simulator -->
  <script>
    const simSurface = document.getElementById('sim-surface') as HTMLInputElement;
    const simIsolation = document.getElementById('sim-isolation') as HTMLSelectElement;
    const simOrientation = document.getElementById('sim-orientation') as HTMLSelectElement;
    const simEtage = document.getElementById('sim-etage') as HTMLSelectElement;
    const simResult = document.getElementById('sim-result');

    const calculatePower = () => {
      if (!simSurface || !simIsolation || !simOrientation || !simEtage || !simResult) return;
      const surface = parseFloat(simSurface.value) || 0;
      const isolationFactor = parseFloat(simIsolation.value);
      const orientationFactor = parseFloat(simOrientation.value);
      const etageFactor = parseFloat(simEtage.value);

      // Base: 100W per m² for average conditions
      const powerWatts = surface * 100 * isolationFactor * orientationFactor * etageFactor;
      const powerkW = (powerWatts / 1000).toFixed(1);

      simResult.innerText = `${powerkW} kW`;
    };

    if (simSurface) {
      simSurface.addEventListener('input', calculatePower);
      simIsolation.addEventListener('change', calculatePower);
      simOrientation.addEventListener('change', calculatePower);
      simEtage.addEventListener('change', calculatePower);
    }
  </script>
</Layout>
