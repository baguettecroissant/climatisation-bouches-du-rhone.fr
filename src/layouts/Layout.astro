---
import '../styles/global.css';
import config from '../data/config.json';
import communes from '../data/communes.json';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  activeTab?: string;
}

const { 
  title = "Climatisation Bouches-du-Rhône (13) : Installateurs RGE & Devis Gratuit", 
  description = "Comparez les installateurs RGE de climatisation réversible et pompe à chaleur dans les Bouches-du-Rhône (13). Installation sous 48h en cas de canicule, devis gratuit.", 
  canonicalUrl,
  activeTab
} = Astro.props;

const currentYear = new Date().getFullYear();
const normalizedPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonical = canonicalUrl || `https://${config.domain}${normalizedPath}`;

// Top 8 populated communes in BDR
const topCommunes = communes && communes.length ? communes.slice(0, 8) : [];
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://${config.domain}/images/hero-climatisation-bouches-du-rhone.png`} />
    
    <meta name="robots" content="index, follow" />
  </head>
  <body>
    <header>
      <div class="container header-inner">
        <a href="/" class="logo">
          <span>❄️</span> Climatisation 13
        </a>
        <nav class="header-nav" aria-label="Menu principal">
          <a href="/" class={activeTab === 'home' ? 'active' : ''}>Accueil</a>
          <a href="/guides/aides-financieres-climatisation-2026/" class={activeTab === 'aides' ? 'active' : ''}>💶 Aides 2026</a>
          <a href="/guides/climatisation-copropriete-marseille/" class={activeTab === 'copropriete' ? 'active' : ''}>🏢 Copropriété</a>
          <a href="/tarifs/" class={activeTab === 'tarifs' ? 'active' : ''}>Tarifs Pose</a>
          <a href="/communes/" class={activeTab === 'communes' ? 'active' : ''}>Villes 13</a>
        </nav>
        <div>
          <a href="/devis/" class="btn-primary header-cta">Devis Gratuit &rarr;</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container footer-grid">
        <div class="footer-brand">
          <h3 style="margin-bottom:15px;">❄️ Climatisation Bouches-du-Rhône</h3>
          <p style="font-size:15px; color:#94a3b8; line-height:1.6; margin-bottom:20px;">
            Le portail indépendant de comparaison pour l'installation de climatisations réversibles (pompe à chaleur air-air) et pompes à chaleur dans le département des Bouches-du-Rhône (13). RGE Qualipac.
          </p>
          <p style="font-size:14px; color:#64748b;">
            Un service d'information locale pour Marseille, Aix-en-Provence, Aubagne, Martigues, Arles, Salon-de-Provence, Vitrolles et Marignane.
          </p>
        </div>
        
        <div class="footer-links">
          <h3>Villes Principales (13)</h3>
          <ul>
            {topCommunes.map(c => (
              <li>
                <a href={`/climatisation-${c.slug}/`}>Climatisation {c.nom} ({c.codePostal})</a>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="footer-links">
          <h3>Guides & Informations</h3>
          <ul>
            <li><a href="/guides/aides-financieres-climatisation-2026/">Aides financières climatisation 2026</a></li>
            <li><a href="/guides/climatisation-copropriete-marseille/">Guide climatisation en copropriété</a></li>
            <li><a href="/tarifs/">Grille des tarifs de pose 2026</a></li>
            <li><a href="/communes/">Annuaire des communes du 13</a></li>
            <li><a href="/politique-confidentialite/">Politique de confidentialité</a></li>
            <li><a href="/mentions-legales/">Mentions légales</a></li>
          </ul>
        </div>
      </div>
      
      <div class="container footer-bottom">
        <p>&copy; {currentYear} {config.domain}. Tous droits réservés.</p>
        <p style="font-size:13px; color:#64748b;">
          Comparateur gratuit sans engagement. Les estimations d'aides et prix sont indicatifs et dépendent d'une étude technique à domicile par un professionnel qualifié.
        </p>
      </div>
    </footer>

    {Astro.url.pathname !== '/devis' && Astro.url.pathname !== '/devis/' && Astro.url.pathname !== '/confirmation' && Astro.url.pathname !== '/confirmation/' && (
      <div class="mobile-sticky-cta">
        <div class="container-sticky">
          <div class="sticky-text">
            <strong>Climatisation RGE — Devis 24h</strong>
            <span>Estimation d'aides gratuites</span>
          </div>
          <a href="/devis/" class="btn-primary sticky-btn">Devis Gratuit &rarr;</a>
        </div>
      </div>
    )}

    <ExitIntentPopup />
  </body>
</html>
